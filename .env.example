# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/founderradar
# Neon / Supabase: get from your dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/founderradar"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-at-least-32-chars"

# Full URL of the app (no trailing slash)
# Development: http://localhost:3000
# Production: https://yourdomain.com
AUTH_URL="http://localhost:3000"

# ─── Seed ──────────────────────────────────────────────────────────────────────
# Password for the seeded admin account (admin@founderradar.dev)
# Defaults to "Admin123!" if not set
SEED_ADMIN_PASSWORD="Admin123!"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Ingestion ─────────────────────────────────────────────────────────────────
# Optional: GitHub personal access token.
# Without it you get 60 API requests/hour (unauthenticated).
# With it you get 5 000 requests/hour.
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=""

# Secret used to authorize external cron calls to POST /api/ingest.
# Generate with: openssl rand -base64 32
# If left empty, only admin-session requests can trigger ingestion.
INGEST_SECRET="your-ingest-secret-here"
